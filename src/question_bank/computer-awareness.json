    "difficulty": "medium",
    "question": "If an 8-bit integer has a maximum of 256 possible values, what is the highest possible value of a 16-bit integer?",
    "correctId": "d",
    "options": [
      {
        "id": "a",
        "text": "512",
        "label": "A"
      },
      {
        "id": "b",
        "text": "257",
        "label": "B"
      },
      {
        "id": "c",
        "text": "65536",
        "label": "C"
      },
      {
        "id": "d",
        "text": "65535",
        "label": "D"
      }
    ],
    "explanation": "An <span class=\"text-magenta font-bold\">N-bit integer</span> can represent <span class=\"text-green\"><span class=\"text-green font-bold\">2^N unique values</span></span>. The highest possible value for an unsigned <span class=\"text-magenta font-bold\">N-bit integer</span> is <span class=\"text-red\"><span class=\"text-red font-bold\">2^N - 1</span></span>. For an <span class=\"text-orange font-bold\">8-bit integer</span>, values range from <span class=\"text-orange\">0 to (2^8 - 1) = <span class=\"text-orange font-bold\">255</span></span>. Therefore, for a 16-bit integer, values range from <span class=\"text-orange\">0 to (2^16 - 1) = 65535</span>.",
    "pyq": null,
    "created_at": "2026-06-15T04:34:13.034365+00:00"
  },
