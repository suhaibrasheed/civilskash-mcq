    ],
    "explanation": "<span class=\"text-red\"><span class=\"text-red font-bold\">Primary storage</span></span>, also known as <span class=\"text-teal\"><span class=\"text-teal font-bold\">main memory</span></span>, is directly accessible by the <span class=\"text-teal\"><span class=\"text-teal font-bold\">CPU</span></span>. <span class=\"text-teal\"><span class=\"text-teal font-bold\">PROM</span></span> (Programmable Read-Only Memory) is a type of <span class=\"text-teal\">ROM</span>, which is a form of <span class=\"text-green\"><span class=\"text-red font-bold\">primary storage</span></span>. <span class=\"text-red\">Magnetic tape and floppy disks are <span class=\"text-red font-bold\">secondary storage devices</span>.</span>",
    "pyq": null,
    "created_at": "2026-06-15T04:34:13.034365+00:00"
